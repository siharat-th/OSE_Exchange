{
    "version": 3,
  "configurePresets": [
    {
      "name": "linux-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "cacheVariables": {
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "vendor": {
        "microsoft.com/VisualStudioRemoteSettings/CMake/1.0": {
          "sourceDir": "$env{HOME}/.vs/$ms{projectDirName}",
          "copySourcesOptions": {
            "excludeList": [ ".vs", ".git", "out", "doc", ".devcontainer" ]
          },
          "copyBuildOutput": false
        }
      }
    },
    {
      "name": "dev-linux-debug",
      "displayName": "[Dev] Linux Debug",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "AKL_TARGET_ENV": "dev",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache"
      }
    },
    {
      "name": "dev-linux-release",
      "displayName": "[Dev] Linux Release",
      "inherits": "linux-base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "AKL_TARGET_ENV": "dev",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache"
      }
    },
    {
      "name": "test-linux-debug",
      "displayName": "[Test] Linux Test",
      "inherits": "linux-base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "AKL_TARGET_ENV": "test",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
		"AKL_TEST_MODE": "true"
      }
    },
    {
      "name": "test-linux-release",
      "displayName": "[Test] Linux Release",
      "inherits": "linux-base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "AKL_TARGET_ENV": "test",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
		"AKL_TEST_MODE": "true"
      }
	}
  ]
}
